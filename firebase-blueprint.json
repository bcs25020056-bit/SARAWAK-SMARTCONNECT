{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information and progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "bio": { "type": "string" },
        "level": { "type": "number" },
        "xp": { "type": "number" },
        "badges": { "type": "number" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "education": { "type": "array", "items": { "type": "object" } },
        "companyInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "industry": { "type": "string" },
            "website": { "type": "string" },
            "location": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "onboarded": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["student", "company", "admin"] }
      },
      "required": ["uid", "displayName", "email", "onboarded", "role"]
    },
    "Job": {
      "title": "Job",
      "description": "Job posting details",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "company": { "type": "string" },
        "companyId": { "type": "string" },
        "location": { "type": "string" },
        "type": { "type": "string" },
        "salary": { "type": "string" },
        "description": { "type": "string" },
        "postedAt": { "type": "string", "format": "date-time" },
        "icon": { "type": "string" }
      },
      "required": ["title", "company", "companyId"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Scholarship": {
      "title": "Scholarship",
      "description": "Scholarship details",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "provider": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "string" },
        "eligibility": { "type": "string" },
        "link": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "provider", "category", "amount", "eligibility", "link"]
    },
    "Application": {
      "title": "Application",
      "description": "Job or scholarship application",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "candidateName": { "type": "string" },
        "jobId": { "type": "string" },
        "jobTitle": { "type": "string" },
        "company": { "type": "string" },
        "companyId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "progress": { "type": "number" },
        "appliedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["Job", "Scholarship"] }
      },
      "required": ["userId", "jobId", "status", "progress", "companyId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Job postings collection"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications collection"
    },
    "/scholarships/{scholarshipId}": {
      "schema": "Scholarship",
      "description": "Scholarships collection"
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Applications collection (Jobs and Scholarships)"
    }
  }
}
