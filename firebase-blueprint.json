{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information and progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "bio": { "type": "string" },
        "level": { "type": "number" },
        "xp": { "type": "number" },
        "badges": { "type": "number" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "education": { "type": "array", "items": { "type": "object" } },
        "onboarded": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string" }
      },
      "required": ["uid", "displayName", "email", "onboarded"]
    },
    "Job": {
      "title": "Job",
      "description": "Job posting details",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "type": { "type": "string" },
        "salary": { "type": "string" },
        "description": { "type": "string" },
        "postedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Job postings collection"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications collection"
    }
  }
}
